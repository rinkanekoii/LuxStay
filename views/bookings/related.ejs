<% const pageTitle = 'Gợi ý liên quan'; %>
<%- include('../partials/header') %>

<section class="page-hero bookings-hero">
  <div class="container page-hero-inner">
    <p class="eyebrow">Booking insights</p>
    <h1 class="page-title">Gợi ý liên quan</h1>
    <p class="page-subtitle">Các phòng thường được đặt với yêu cầu tương tự booking #<%= booking.id %>.</p>
  </div>
</section>

<section class="section section-light section-tight">
  <div class="container">
    <div class="panel-header page-actions">
      <div>
        <p class="eyebrow">Reference</p>
        <h2><%= booking.room_name %></h2>
        <p><%= booking.city %> · <%= booking.type %></p>
      </div>
      <a href="/bookings" class="btn btn-outline">Quay lại booking</a>
    </div>

    <% if (booking.note) { %>
      <div class="panel-card report-context">
        <strong>Yêu cầu đã lưu</strong>
        <p><%= booking.note %></p>
      </div>
    <% } %>

    <% if (relatedError) { %>
      <div class="panel-card report-error">
        <strong>Không thể tải gợi ý</strong>
        <p><%= relatedError %></p>
      </div>
    <% } else if (rows.length) { %>
      <div class="panel-card report-table-card">
        <table class="report-table">
          <thead>
            <tr>
              <th>Phòng</th>
              <th>Thành phố</th>
              <th>Loại</th>
              <th>Lượt tương tự</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach((row) => { %>
              <tr>
                <td><%= row.room_name %></td>
                <td><%= row.city %></td>
                <td><%= row.room_type %></td>
                <td><%= row.bookings_count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-card wide">
        <h2>Chưa có gợi ý phù hợp</h2>
        <p>Hệ thống chưa tìm được booking có yêu cầu tương tự.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
