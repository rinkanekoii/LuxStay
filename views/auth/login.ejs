<% const pageTitle = 'Đăng nhập'; %>
<%- include('../partials/header') %>

<section class="auth-section image-auth">
  <div class="auth-shell">
    <div class="auth-copy glass-panel">
      <p class="eyebrow">Member access</p>
      <h1>Đăng nhập để quản lý chuyến đi.</h1>
      <p>Vào dashboard để xem booking, đặt phòng mới và theo dõi các yêu cầu đã gửi.</p>
      <div class="auth-feature-list">
        <span>Đặt phòng nhanh</span>
        <span>Quản lý lịch lưu trú</span>
        <span>Hỗ trợ nội bộ</span>
      </div>
    </div>

    <div class="auth-card elevated-card">
      <div class="auth-header">
        <h2>Chào mừng trở lại</h2>
        <p>Nhập thông tin tài khoản LuxStay</p>
      </div>

      <% if (error) { %>
        <div class="form-alert form-alert-error"><%= error %></div>
      <% } %>

      <form action="/auth/login" method="POST" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
          <label for="username" class="form-label">Tên đăng nhập</label>
          <input type="text" id="username" name="username" class="form-input"
                 value="<%= username %>" required autocomplete="username" placeholder="Nhập username">
        </div>

        <div class="form-group">
          <label for="password" class="form-label">Mật khẩu</label>
          <input type="password" id="password" name="password" class="form-input"
                 required autocomplete="current-password" placeholder="Nhập mật khẩu">
        </div>

        <button type="submit" class="btn btn-primary btn-full">Vào dashboard</button>
      </form>

      <div class="auth-footer">
        <a href="/rooms" class="form-link">Xem phòng</a>
        <span>·</span>
        <a href="/contact" class="form-link">Cần hỗ trợ?</a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
