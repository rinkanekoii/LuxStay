<% const pageTitle = 'Liên hệ'; %>
<%- include('../partials/header') %>

<section class="page-header">
  <div class="container">
    <h1 class="page-title">Liên Hệ</h1>
    <p class="page-subtitle">Gửi yêu cầu tới bộ phận hỗ trợ</p>
  </div>
</section>

<section class="section">
  <div class="container" style="max-width:520px">
    <% if (verifiedMsg) { %>
      <div class="form-alert form-alert-success" style="margin-bottom:20px"><%= verifiedMsg %></div>
    <% } %>

    <div class="detail-card">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="form-alert form-alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/contact" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label" for="sender_name">Người gửi</label>
          <input type="text" id="sender_name" name="sender_name" class="form-input"
                 value="<%= senderName %>" autocomplete="name">
        </div>
        <div class="form-group">
          <label class="form-label" for="body">Nội dung</label>
          <textarea id="body" name="body" class="form-input form-textarea" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Gửi</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
