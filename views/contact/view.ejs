<% const pageTitle = 'Chi tiết liên hệ'; %>
<%- include('../partials/header') %>

<section class="page-hero contact-hero small">
  <div class="container page-hero-inner">
    <p class="eyebrow">Message</p>
    <h1 class="page-title">Chi tiết yêu cầu</h1>
  </div>
</section>

<section class="section section-light section-tight">
  <div class="container narrow">
    <div class="detail-card elevated-card">
      <p class="text-muted meta-line">
        #<%= message.id %> · <%= new Date(message.created_at).toLocaleString('vi-VN') %>
        <% if (message.sender_name) { %> · <%= message.sender_name %><% } %>
      </p>

      <div class="contact-message-body"><%= message.body %></div>

      <div class="message-tools">
        <button type="button" class="btn btn-ghost btn-sm message-preview-trigger"
                data-preview-target="#messagePreview"
                data-preview-content="<%= message.body %>">
          Xem bản định dạng
        </button>
      </div>

      <div id="messagePreview" class="message-preview-box" aria-live="polite"></div>
    </div>

    <p class="center-links">
      <a href="/contact" class="form-link">Gửi yêu cầu mới</a>
      <span>·</span>
      <a href="/dashboard" class="form-link">Dashboard</a>
    </p>
  </div>
</section>

<%- include('../partials/footer') %>
