<% const pageTitle = 'Chi tiết liên hệ'; %>
<%- include('../partials/header') %>

<section class="section">
  <div class="container" style="max-width:560px">
    <% if (verifiedMsg) { %>
      <div class="form-alert form-alert-success" style="margin-bottom:20px"><%= verifiedMsg %></div>
    <% } %>

    <div class="detail-card">
      <p class="text-muted" style="font-size:0.8rem;margin-bottom:16px">
        #<%= message.id %> · <%= new Date(message.created_at).toLocaleString('vi-VN') %>
        <% if (message.sender_name) { %> · <%= message.sender_name %><% } %>
      </p>
      <div class="contact-message-body"><%- message.body %></div>
    </div>

    <p style="text-align:center;margin-top:24px">
      <a href="/contact" class="form-link">Gửi tin mới</a> · <a href="/" class="form-link">Trang chủ</a>
    </p>
  </div>
</section>

<%- include('../partials/footer') %>
